# Base URL of the Laravel API (include the /api suffix)
VITE_API_BASE_URL=http://localhost:8000/api

# Upload API endpoint for report images (POST with body: { "path": "..." })
VITE_UPLOADS_API_URL=http://192.168.214.163:4000/api/uploads

# Application display name
VITE_APP_NAME=GH PIK2


# go2rtc WebRTC signalling URLs for the 4 live CCTV feeds (low latency).
# The player connects to these WebSocket endpoints, NOT the raw rtsp URLs.
VITE_STREAM_URL_1=http://localhost:1984/api/ws?src=cam1
VITE_STREAM_URL_2=http://localhost:1984/api/ws?src=cam2
VITE_STREAM_URL_3=http://localhost:1984/api/ws?src=cam3
VITE_STREAM_URL_4=http://localhost:1984/api/ws?src=cam4

# MQTT broker WebSocket URL (EMQX default path: /mqtt)
VITE_MQTT_BROKER_URL=ws://192.168.214.163:8083/mqtt
